# ─── Frontend (React) ───────────────────────────────────────
# Google OAuth Client ID (공개 값, REACT_APP_ 접두사 필수)
REACT_APP_GOOGLE_CLIENT_ID=your_google_client_id_here
REACT_APP_GOOGLE_REDIRECT_URI=https://your-vercel-domain.vercel.app/api/auth/google/callback

# ─── Backend (Vercel Serverless) ────────────────────────────
# Google OAuth Client Secret (절대 공개 금지)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=https://your-vercel-domain.vercel.app/api/auth/google/callback

# 배포된 프론트엔드 URL (CORS 허용)
FRONTEND_URL=https://your-vercel-domain.vercel.app

# ─── 로컬 개발 시 (.env.local 에 복사해서 사용) ─────────────
# REACT_APP_GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
# GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
# FRONTEND_URL=http://localhost:3000
